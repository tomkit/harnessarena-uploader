{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessarena.com/schemas/upload-batch.json",
  "version": "0.1.0",
  "$ref": "#/$defs/UploadBatch",
  "$defs": {
    "Harness": {
      "type": "string",
      "enum": [
        "claude",
        "gemini",
        "codex",
        "agent",
        "opencode"
      ]
    },
    "HarnessMeta": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/Harness"
        },
        "cli_version": {
          "type": "string"
        },
        "os_name": {
          "type": "string"
        },
        "os_arch": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "shell": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "default_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "plugin_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "config_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "available_tools": {
          "default": []
        },
        "available_skills": {
          "default": []
        },
        "available_mcp_servers": {
          "default": []
        },
        "available_agents": {
          "default": []
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "cli_version",
        "os_name",
        "os_arch",
        "provider",
        "shell",
        "source"
      ]
    },
    "SessionMeta": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "source_session_id": {
          "type": "string"
        },
        "harness": {
          "$ref": "#/$defs/Harness"
        },
        "harness_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "project_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "git_repo_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "git_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "message_count_user": {
          "type": "integer"
        },
        "message_count_assistant": {
          "type": "integer"
        },
        "message_count_total": {
          "type": "integer"
        },
        "tool_call_count": {
          "type": "integer"
        },
        "tokens": {
          "$ref": "#/$defs/TokenUsage"
        },
        "parent_session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "agent_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "subagent_calls": {
          "type": "integer",
          "default": 0
        },
        "background_agents": {
          "type": "integer",
          "default": 0
        },
        "mcp_calls": {
          "type": "integer",
          "default": 0
        },
        "plan_mode_entries": {
          "type": "integer",
          "default": 0
        },
        "plan_mode_exits": {
          "type": "integer",
          "default": 0
        },
        "tool_calls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ToolCallSummary"
          },
          "default": []
        },
        "subagents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SubagentMeta"
          },
          "default": []
        },
        "skills_used": {
          "type": "object",
          "default": {}
        },
        "mcp_servers": {
          "type": "object",
          "default": {}
        },
        "daily": {
          "type": "array",
          "default": []
        },
        "cost_usd": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "data_completeness": {
          "type": "string",
          "default": "full"
        },
        "is_pruned": {
          "type": "boolean",
          "default": false
        },
        "intervention_rate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "total_exec_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mean_turn_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "median_turn_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "time_spans": {
          "type": "array",
          "default": []
        },
        "started_at": {
          "type": "string",
          "default": ""
        },
        "ended_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "duration_seconds": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "source_session_id",
        "harness",
        "harness_version",
        "project_name",
        "git_repo_name",
        "git_branch",
        "model",
        "provider",
        "message_count_user",
        "message_count_assistant",
        "message_count_total",
        "tool_call_count",
        "tokens"
      ]
    },
    "SubagentMeta": {
      "type": "object",
      "properties": {
        "ordinal": {
          "type": "integer"
        },
        "parent_ordinal": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mode": {
          "type": "string",
          "default": "foreground"
        },
        "subagent_type": {
          "type": "string",
          "default": ""
        },
        "nickname": {
          "type": "string",
          "default": ""
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "depth": {
          "type": "integer",
          "default": 1
        },
        "total_tokens": {
          "type": "integer",
          "default": 0
        },
        "total_tool_calls": {
          "type": "integer",
          "default": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "ordinal"
      ]
    },
    "TokenUsage": {
      "type": "object",
      "properties": {
        "input_tokens": {
          "type": "integer",
          "default": 0
        },
        "output_tokens": {
          "type": "integer",
          "default": 0
        },
        "cache_read_tokens": {
          "type": "integer",
          "default": 0
        },
        "cache_write_tokens": {
          "type": "integer",
          "default": 0
        },
        "total_tokens": {
          "type": "integer",
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "ToolCallSummary": {
      "type": "object",
      "properties": {
        "tool_name": {
          "type": "string"
        },
        "invocation_count": {
          "type": "integer"
        },
        "category": {
          "type": "string",
          "default": "tool"
        }
      },
      "additionalProperties": false,
      "required": [
        "tool_name",
        "invocation_count"
      ]
    },
    "UploadBatch": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "tool_version": {
          "type": "string"
        },
        "harnesses_scanned": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Harness"
          }
        },
        "harness_meta": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HarnessMeta"
          }
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SessionMeta"
          }
        },
        "machine_id": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "schema_version": {
          "type": "string",
          "default": "0.1.0"
        },
        "session_count": {
          "type": "integer",
          "default": 0
        },
        "total_tokens": {
          "type": "integer",
          "default": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "tool_version",
        "harnesses_scanned",
        "harness_meta",
        "sessions",
        "machine_id",
        "created_at"
      ]
    }
  }
}
